    {
        "id": "map_data_live",
        "type": "function",
        "z": "marine_ts_live",
        "name": "Map Live Data",
        "func": "const f = msg.payload || {};\nconst ts = f.created_at ? new Date(f.created_at).getTime() : Date.now();\n\nconst sensors = {\n  do: Number(parseFloat(f.field1) || 0),\n  ph: Number(parseFloat(f.field2) || 0),\n  salinity: Number(parseFloat(f.field3) || 0),\n  turbidity: Number(parseFloat(f.field4) || 0),\n  temp: Number(parseFloat(f.field5) || 0),\n  speed: Number(parseFloat(f.field6) || 0),\n  dir: Number(parseFloat(f.field7) || 0)\n};\n\nreturn [\n  { payload: sensors.do, topic: \"Dissolved Oxygen\", timestamp: ts },\n  { payload: sensors.ph, topic: \"pH\", timestamp: ts },\n  { payload: sensors.salinity, topic: \"Salinity\", timestamp: ts },\n  { payload: sensors.turbidity, topic: \"Turbidity\", timestamp: ts },\n  { payload: sensors.temp, topic: \"Water Temperature\", timestamp: ts },\n  { payload: sensors.speed, topic: \"Current Speed\", timestamp: ts },\n  { payload: sensors.dir, topic: \"Current Direction\", timestamp: ts },\n  {\n    payload: {\n      ts: ts,\n      speed: sensors.speed,\n      dir: sensors.dir\n    },\n    topic: \"Current Vector\",\n    timestamp: ts\n  }\n];",
        "outputs": 8,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 220,
        "wires": [
            [
                "c1",
                "g1"
            ],
            [
                "c2",
                "g2"
            ],
            [
                "c3",
                "g3"
            ],
            [
                "c4",
                "g4"
            ],
            [
                "c5",
                "g5"
            ],
            [
                "c6",
                "g6"
            ],
            [
                "compass_dir"
            ],
            [
                "dir_plot_time_svg",
                "debug_vector"
            ]
        ]
    },
    {
        "id": "map_history_for_svg",
        "type": "function",
        "z": "marine_ts_live",
        "name": "Map History For SVG",
        "func": "const feeds = msg.payload && msg.payload.feeds ? msg.payload.feeds : [];\n\nmsg.payload = {\n  mode: \"history\",\n  points: feeds\n    .filter(f => f.field6 !== null && f.field7 !== null)\n    .map(f => ({\n      ts: new Date(f.created_at).getTime(),\n      speed: Number(parseFloat(f.field6) || 0),\n      dir: Number(parseFloat(f.field7) || 0)\n    }))\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 280,
        "wires": [
            [
                "debug_hist_mapped",
                "92ddc1294fe57c9e"
            ]
        ]
    },
