    {
        "id": "dir_plot_time_svg",
        "type": "ui-template",
        "z": "marine_ts_live",
        "group": "grp7",
        "page": "",
        "ui": "",
        "name": "Direction Time-Speed SVG Plot",
        "order": 2,
        "width": 8,
        "height": 6,
        "format": "<template>\n  <div class=\"dir-wrap\">\n    <div class=\"dir-head\">\n      <div class=\"dir-title\">Current Speed vs Time</div>\n      <div class=\"dir-sub\">Arrow angle = current direction, visible window = last 2 hours / 1000 points</div>\n    </div>\n\n    <div class=\"dir-svg-wrap\">\n      <svg viewBox=\"0 0 1000 320\" preserveAspectRatio=\"none\" class=\"dir-svg\">\n        <line :x1=\"xMin\" :y1=\"yMax\" :x2=\"xMax\" :y2=\"yMax\" class=\"axis-line\" />\n        <line :x1=\"xMin\" :y1=\"yMin\" :x2=\"xMin\" :y2=\"yMax\" class=\"axis-line\" />\n\n        <g v-for=\"tick in yTicks\" :key=\"'y' + tick.value\">\n          <line :x1=\"xMin - 6\" :y1=\"tick.y\" :x2=\"xMin\" :y2=\"tick.y\" class=\"tick-line\" />\n          <text :x=\"xMin - 10\" :y=\"tick.y + 4\" class=\"axis-text tick-label\" text-anchor=\"end\">{{ tick.label }}</text>\n          <line :x1=\"xMin\" :y1=\"tick.y\" :x2=\"xMax\" :y2=\"tick.y\" class=\"grid-line\" />\n        </g>\n\n        <g v-for=\"tick in xTicks\" :key=\"'x' + tick.value\">\n          <line :x1=\"tick.x\" :y1=\"yMax\" :x2=\"tick.x\" :y2=\"yMax + 6\" class=\"tick-line\" />\n          <text :x=\"tick.x\" :y=\"yMax + 20\" class=\"axis-text tick-label\" text-anchor=\"middle\">{{ tick.label }}</text>\n          <line :x1=\"tick.x\" :y1=\"yMin\" :x2=\"tick.x\" :y2=\"yMax\" class=\"grid-line vertical-grid\" />\n        </g>\n\n        <text :x=\"xMax - 5\" :y=\"yMax + 38\" class=\"axis-text axis-title\" text-anchor=\"end\">Time</text>\n        <text :x=\"xMin - 38\" :y=\"yMin + 8\" class=\"axis-text axis-title\">Speed</text>\n\n        <polyline v-if=\"points.length > 1\" :points=\"linePoints\" class=\"track-line\" />\n\n        <g v-for=\"(p, i) in points\" :key=\"p.ts + '_' + i\">\n          <g :transform=\"arrowTransform(p)\">\n            <polygon :points=\"arrowPoints(i)\" :fill=\"speedColor(p.speed)\" :stroke=\"speedColor(p.speed)\"\n              :stroke-width=\"arrowStroke(i)\" />\n          </g>\n        </g>\n      </svg>\n    </div>\n  </div>\n</template>\n\n<script>\n  export default {\n  data() {\n    return {\n      points: [],\n      maxPoints: 1000,\n      maxAgeMs: 2 * 60 * 60 * 1000,\n      maxSpeed: 5,\n      xMin: 70,\n      xMax: 980,\n      yMin: 20,\n      yMax: 270\n    }\n  },\n\n  mounted() {\n    this.$socket.on('msg-input:' + this.id, this.onInput)\n\n    this.$nextTick(() => {\n      this.$socket.send({\n        topic: 'load-results',\n        payload: { request: 'history' }\n      })\n    })\n  },\n\n  unmounted() {\n    this.$socket.off('msg-input:' + this.id, this.onInput)\n  },\n\n  watch: {\n    msg: {\n      deep: true,\n      immediate: false,\n      handler() {\n        this.onInput(this.msg)\n      }\n    }\n  },\n\n  methods: {\n    onInput(msg) {\n      if (!msg || !msg.payload) return\n\n      // If server is sending history\n      if (msg.topic === 'load-results' && Array.isArray(msg.payload.points)) {\n        this.points = msg.payload.points.map(v => ({\n          ts: Number(v.ts ?? Date.now()),\n          speed: Number(v.speed ?? 0),\n          dir: Number(v.dir ?? 0)\n        }))\n        this.trimPoints()\n        return\n      }\n\n      // Normal history/appends\n      if (msg.payload.mode === 'history' && Array.isArray(msg.payload.points)) {\n        this.points = msg.payload.points.map(v => ({\n          ts: Number(v.ts ?? Date.now()),\n          speed: Number(v.speed ?? 0),\n          dir: Number(v.dir ?? 0)\n        }))\n        this.trimPoints()\n        return\n      }\n\n      if (msg.payload.mode === 'append' && msg.payload.point) {\n        this.points.push({\n          ts: Number(msg.payload.point.ts ?? Date.now()),\n          speed: Number(msg.payload.point.speed ?? 0),\n          dir: Number(msg.payload.point.dir ?? 0)\n        })\n        this.trimPoints()\n        return\n      }\n\n      if (msg.payload.ts !== undefined && msg.payload.speed !== undefined && msg.payload.dir !== undefined) {\n        this.points.push({\n          ts: Number(msg.payload.ts ?? Date.now()),\n          speed: Number(msg.payload.speed ?? 0),\n          dir: Number(msg.payload.dir ?? 0)\n        })\n        this.trimPoints()\n      }\n    },\n\n    trimPoints() {\n      const cutoff = Date.now() - this.maxAgeMs\n      this.points = this.points\n        .filter(p => Number(p.ts) >= cutoff)\n        .sort((a, b) => a.ts - b.ts)\n\n      if (this.points.length > this.maxPoints) {\n        this.points = this.points.slice(-this.maxPoints)\n      }\n    },\n\n    speedColor(speed) {\n      if (speed < 0.5) return '#22c55e'\n      if (speed < 1.5) return '#84cc16'\n      if (speed < 2.5) return '#eab308'\n      if (speed < 3.5) return '#f97316'\n      return '#ef4444'\n    },\n\n    minTs() {\n      return Date.now() - this.maxAgeMs\n    },\n\n    maxTs() {\n      return Date.now()\n    },\n\n    toSvgX(ts) {\n      const min = this.minTs()\n      const max = this.maxTs()\n      return this.xMin + ((ts - min) / (max - min)) * (this.xMax - this.xMin)\n    },\n\n    toSvgY(speed) {\n      const min = 0\n      const max = this.maxSpeed\n      return this.yMax - ((speed - min) / (max - min)) * (this.yMax - this.yMin)\n    },\n\n    arrowTransform(p) {\n      return `translate(${this.toSvgX(p.ts)}, ${this.toSvgY(p.speed)}) rotate(${p.dir})`\n    },\n\n    arrowPoints(i) {\n      const isLatest = i === this.points.length - 1\n      return isLatest ? '0,-18 12,12 0,6 -12,12' : '0,-12 8,8 0,4 -8,8'\n    },\n\n    arrowStroke(i) {\n      return i === this.points.length - 1 ? 2.5 : 1.5\n    },\n\n    formatTime(ts) {\n      const d = new Date(ts)\n      const hh = String(d.getHours()).padStart(2, '0')\n      const mm = String(d.getMinutes()).padStart(2, '0')\n      return `${hh}:${mm}`\n    }\n  },\n\n  computed: {\n    linePoints() {\n      return this.points\n        .map(p => `${this.toSvgX(p.ts)},${this.toSvgY(p.speed)}`)\n        .join(' ')\n    },\n\n    yTicks() {\n      const steps = 5\n      const arr = []\n      for (let i = 0; i <= steps; i++) {\n        const value = (this.maxSpeed / steps) * i\n        arr.push({\n          value,\n          label: value.toFixed(1),\n          y: this.toSvgY(value)\n        })\n      }\n      return arr\n    },\n\n    xTicks() {\n      const min = this.minTs()\n      const max = this.maxTs()\n      const steps = 4\n      const arr = []\n\n      for (let i = 0; i <= steps; i++) {\n        const value = min + ((max - min) / steps) * i\n        arr.push({\n          value,\n          label: this.formatTime(value),\n          x: this.toSvgX(value)\n        })\n      }\n      return arr\n    }\n  }\n}\n</script>\n\n<style>\n  .dir-wrap {\n    height: 100%;\n    min-height: 330px;\n    background: linear-gradient(180deg, #0f172a 0%, #111827 100%);\n    border: 1px solid #334155;\n    border-radius: 14px;\n    padding: 10px 12px 12px 12px;\n    box-sizing: border-box;\n  }\n\n  .dir-head {\n    margin-bottom: 8px;\n  }\n\n  .dir-title {\n    color: #e5e7eb;\n    font-size: 16px;\n    font-weight: 700;\n  }\n\n  .dir-sub {\n    color: #94a3b8;\n    font-size: 12px;\n    margin-top: 2px;\n  }\n\n  .dir-svg-wrap {\n    width: 100%;\n    height: 285px;\n  }\n\n  .dir-svg {\n    width: 100%;\n    height: 100%;\n    display: block;\n  }\n\n  .axis-line {\n    stroke: rgba(148, 163, 184, 0.55);\n    stroke-width: 1.5;\n  }\n\n  .tick-line {\n    stroke: rgba(148, 163, 184, 0.55);\n    stroke-width: 1.2;\n  }\n\n  .grid-line {\n    stroke: rgba(148, 163, 184, 0.12);\n    stroke-width: 1;\n  }\n\n  .vertical-grid {\n    stroke: rgba(148, 163, 184, 0.10);\n  }\n\n  .axis-text {\n    fill: #cbd5e1;\n    font-size: 12px;\n  }\n\n  .tick-label {\n    fill: #94a3b8;\n  }\n\n  .axis-title {\n    fill: #e5e7eb;\n    font-size: 13px;\n    font-weight: 600;\n  }\n\n  .track-line {\n    fill: none;\n    stroke: rgba(56, 189, 248, 0.35);\n    stroke-width: 2;\n  }\n</style>",
        "storeOutMessages": true,
